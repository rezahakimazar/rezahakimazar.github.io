##setting path
rm(list = ls())
setwd("C:\\Users\\User\\Desktop\\StatisticsCourse2024-main\\Session03") #set to your path
##importing csv table
data <- read_xlsx("dataset.xlsx")
View(data)
##histogram
hist(data$DEPRESSION, col = "cyan",
border = "black", main = "Depression Distribution",
xlab = "Depression Score",
ylab = "How Frequent It Is",
ylim = c(0,250))
abline(v=median(data$DEPRESSION), col = "darkgreen", lwd = 2, lty = 3)
abline(h=15.7)
hist(data$`ANXIETY TRAIT`, col = "indianred", xlab = "Anxieety Trait Score", ylab = "How Frequent They Are",
main = "Anxiety Trait Histogram", ylim = c(0,200))
abline(v=mean(data$`ANXIETY TRAIT`), col = "mintcream", lwd = 2, lty = 2)
summary(data$`ANXIETY TRAIT`)
abline(v=18, lty = 3, col = "white", lwd = 2)
abline(v=36)
plot(x = data$DEPRESSION[data$SEX == "man"] ,
y = data$`ANXIETY TRAIT`[data$SEX == "man"],
xlab = "Depression Scores", ylab = "Anxiety Scores",
col = "navy", pch = 1,
)
points(x = data$DEPRESSION[data$SEX == "woman"],
y = data$`ANXIETY TRAIT`[data$SEX == "woman"],
pch = 5, col = "red")
legend("bottomright", legend = c("Men", "Women"),
pch = c(1,5), col = c("navy","red"))
abline(line(x = data$DEPRESSION , y = data$`ANXIETY STATE`),
col = "lavenderblush" , lty = 3 , lwd = 4)
abline(line(x = data$DEPRESSION[data$SEX == "man"],
y = data$`ANXIETY TRAIT`[data$SEX == "man"] ))
abline(line(x = data$DEPRESSION[data$SEX == "woman"],
y = data$`ANXIETY TRAIT`[data$SEX == "woman"]))
plot(x = data$`SUIC RISK`,
y = data$AGE,
xlab = "Suicide Risk",
ylab = "Age")
abline(line(x = data$`SUIC RISK`,
y = data$AGE),
col = "red")
