y = data$`ANXIETY TRAIT`[data$SEX == "man"] ))
abline(line(x = data$DEPRESSION[data$SEX == "woman"],
y = data$`ANXIETY TRAIT`[data$SEX == "woman"]))
plot(x = data$`SUIC RISK`,
y = data$AGE,
xlab = "Suicide Risk",
ylab = "Age")
abline(line(x = data$`SUIC RISK`,
y = data$AGE),
col = "red")
data$`ECONOMIC INCOME`
tabulate(as.factor(data$`ECONOMIC INCOME`))
pie(x = c(178, 922), labels = c("no income", "with income"), col = c("orange","lavender"))
barplot(height = c(188, 922), names.arg = c("no", "yes"), ylim = c(0,1000))
barplot(height = c(mean(data$DEPRESSION[data$SEX == "man"]), mean(data$DEPRESSION[data$SEX == "woman"])),
names.arg = c("men", "women"), ylim = c(0, 20),
col = c("indianred", "navyblue"))
abline(h=11)
boxplot(data$DEPRESSION ~ data$`ECONOMIC INCOME`, data = data,
col = c("limegreen", "steelblue"),
main = "Boxplot for Depression & Income",
xlab = "Do You Have a Relible Source of Income?",
ylab = "Depression Score",
ylim = c(0,70))
